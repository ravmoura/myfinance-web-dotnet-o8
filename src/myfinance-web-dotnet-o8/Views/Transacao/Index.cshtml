@using myfinance_web_dotnet_o8.Domain
@{
    ViewData["Title"] = "Transação";
}

<button type="button" class="btn btn-block btn-primary" onclick="Novo()">Criar Nova Transação</button>
<br><br>

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Histórico</th>
        <th>Tipo Plano Conta</th>
        <th>Valor</th>
        <th>Data</th>                
        <th>#</th>
        <th>#</th>
    </tr>

@{
    foreach(var item in (List<Transacao>)ViewBag.ListaTransacao) {
        <tr>
            <td>@item.Id</td>
            <td>@item.Historico</td>
            <td>@item.ItemPlanoConta.Tipo</td>
            <td>@item.Valor</td>
            <td>@item.Data</td>                        
            <td>
                <button type="button" class="btn btn-block btn-outline-warning" onclick="Editar(@item.Id.ToString())">Editar</button> &nbsp;
            </td>
            <td>
                <button type="button" class="btn btn-block btn-outline-danger" onclick="Excluir(@item.Id.ToString())">Excluir</button>
            </td>
        </tr>        
    }
}
</table>

<script>
    function Novo() {
        window.location.href = "../Transacao/Cadastro";
    }

    function Editar(id) {
        window.location.href = "../Transacao/Cadastro/" + id;
    }

    function Excluir(id) {
        window.location.href = "../Transacao/Excluir/" + id;
    }
</script>