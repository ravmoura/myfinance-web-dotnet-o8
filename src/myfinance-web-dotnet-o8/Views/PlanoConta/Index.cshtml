@using myfinance_web_dotnet_o8.Domain
@using myfinance_web_dotnet_o8.Models
@{
    ViewData["Title"] = "Plano Conta";
}

<button type="button" class="btn btn-block btn-primary" onclick="Novo()">Criar Novo Plano de Conta</button>
<br><br>

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Descrição</th>
        <th>Tipo</th>
        <th>#</th>
        <th>#</th>
    </tr>

@{
    foreach(var item in (List<PlanoConta>)ViewBag.ListaPlanoConta) {
        <tr>
            <td>@item.Id</td>
            <td>@item.Nome</td>
            <td>@item.Tipo</td>
            <td>
                <button type="button" class="btn btn-block btn-outline-warning" onclick="Editar(@item.Id.ToString())">Editar</button> &nbsp;
            </td>
            <td>
                <button type="button" class="btn btn-block btn-outline-danger" onclick="Excluir(@item.Id.ToString())">Excluir</button>
            </td>
        </tr>        
    }
}
</table>

<script>
    function Novo() {
        window.location.href = "../PlanoConta/Cadastro";
    }

    function Editar(id) {
        window.location.href = "../PlanoConta/Cadastro/" + id;
    }

    function Excluir(id) {
        window.location.href = "../PlanoConta/Excluir/" + id;
    }
</script>